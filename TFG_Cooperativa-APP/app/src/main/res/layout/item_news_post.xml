<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_base"
    style="@style/Widget.CooperativaLaVera.CardView"
    app:strokeColor="@color/green_200"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Emoji/image box -->
        <FrameLayout
            android:layout_width="@dimen/item_thumbnail_size"
            android:layout_height="@dimen/item_thumbnail_size"
            android:background="@color/green_100">

            <TextView
                android:id="@+id/tvPostEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="32sp" />
        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <TextView
                android:id="@+id/tvPostTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="@color/green_900"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <!-- Date row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:src="@android:drawable/ic_menu_today"
                    android:tint="@color/green_600"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvPostDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/green_600" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPostContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/gray_700" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>