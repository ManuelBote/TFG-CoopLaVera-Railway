<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingBottom="@dimen/bottom_nav_height">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header gradient -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_welcome"
                android:textSize="@dimen/text_2xl"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="@color/green_50"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/home_address"
                    android:textColor="@color/green_50"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>
        </LinearLayout>

        <!-- News section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_base"
            android:paddingEnd="@dimen/spacing_base"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_sm">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_news_title"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_base" />

            <!-- RecyclerView for news posts -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- About section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/green_50"
            android:padding="@dimen/spacing_base"
            android:paddingTop="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_about_title"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_about_text1"
                android:textColor="@color/gray_700"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_about_text2"
                android:textColor="@color/gray_700" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>