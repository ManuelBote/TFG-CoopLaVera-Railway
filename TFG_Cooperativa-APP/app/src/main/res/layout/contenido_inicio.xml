<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inicio_bienvenida"
                android:textSize="@dimen/text_2xl"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="@color/green_50"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvDireccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/inicio_direccion"
                    android:textColor="@color/green_50"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_base">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_base"
                android:paddingEnd="@dimen/spacing_base"
                android:text="@string/inicio_foro_titulo"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_base" />

             <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm">

                <LinearLayout
                    android:id="@+id/contenedorForo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/green_50"
            android:paddingStart="@dimen/spacing_base"
            android:paddingEnd="@dimen/spacing_base"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inicio_ubicacion_titulo"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_base" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMapa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgMapa"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/mapa_ubicacion"
                        android:contentDescription="@string/inicio_ubicacion_imagen_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_base"
                        android:background="@color/white">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inicio_ubicacion_direccion1"
                            android:textStyle="italic|bold"
                            android:textSize="@dimen/text_base"
                            android:textColor="@color/green_900" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inicio_ubicacion_direccion2"
                            android:textStyle="italic"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/green_700"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inicio_ubicacion_tocar_hint"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/green_600"
                            android:layout_marginTop="@dimen/spacing_sm" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_base"
                android:paddingEnd="@dimen/spacing_base"
                android:text="@string/inicio_productos_titulo"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_base" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:paddingStart="@dimen/spacing_base"
                android:paddingEnd="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/include_inicio_producto"
                        android:id="@+id/prodHigo" />
                    <include layout="@layout/include_inicio_producto"
                        android:id="@+id/prodHigoSeco" />
                    <include layout="@layout/include_inicio_producto"
                        android:id="@+id/prodCereza" />
                    <include layout="@layout/include_inicio_producto"
                        android:id="@+id/prodArandano" />
                    <include layout="@layout/include_inicio_producto"
                        android:id="@+id/prodCiruela" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/green_50"
            android:padding="@dimen/spacing_base"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inicio_sobrenosotros_titulo"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/green_800"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/inicio_sobrenosotros_texto1"
                android:textColor="@color/gray_700"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/inicio_sobrenosotros_texto2"
                android:textColor="@color/gray_700"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
