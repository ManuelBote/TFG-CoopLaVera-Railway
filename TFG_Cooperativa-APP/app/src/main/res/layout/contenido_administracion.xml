<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_100">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_subtitle"
            android:textColor="@color/green_100"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabProducts"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/admin_products_tab"
                android:textSize="11sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                style="@style/Widget.CooperativaLaVera.Button"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabSolicitudes"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/admin_orders_tab"
                android:textSize="11sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                style="@style/Widget.CooperativaLaVera.Button.Outlined"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabDeliveries"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/admin_deliveries_tab"
                android:textSize="11sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                style="@style/Widget.CooperativaLaVera.Button.Outlined"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabUsuarios"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/admin_users_tab"
                android:textSize="11sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                style="@style/Widget.CooperativaLaVera.Button.Outlined"/>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/panelProducts"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_section_frutas"
                        android:textStyle="bold"
                        android:textColor="@color/green_800"
                        android:textSize="18sp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/rvAdminFrutas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_section_materiales"
                        android:textStyle="bold"
                        android:textColor="@color/green_800"
                        android:textSize="18sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/rvAdminMateriales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <ProgressBar
                android:id="@+id/progressProducts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_600"
                android:visibility="gone"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/panelSolicitudes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNuevaSolicitud"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:text="@string/admin_new_solicitud"
                app:icon="@android:drawable/ic_menu_add"
                style="@style/Widget.CooperativaLaVera.Button"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ListView
                    android:id="@+id/rvAdminSolicitudes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="80dp"
                    android:clipToPadding="false"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="12dp"/>

                <ProgressBar
                    android:id="@+id/progressSolicitudes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/green_600"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvSolicitudesEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/admin_empty_solicitudes"
                    android:textColor="@color/gray_500"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:visibility="gone"/>
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/panelDeliveries"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <ListView
                android:id="@+id/rvAdminDeliveries"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="12dp"/>

            <ProgressBar
                android:id="@+id/progressDeliveries"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_600"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvDeliveriesEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/admin_empty_deliveries"
                android:textColor="@color/gray_500"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/panelUsuarios"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <ListView
                android:id="@+id/rvAdminUsuarios"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="12dp"/>

            <ProgressBar
                android:id="@+id/progressUsuarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/green_600"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvUsuariosEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/admin_empty_users"
                android:textColor="@color/gray_500"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone"/>
        </FrameLayout>

    </FrameLayout>

</LinearLayout>
