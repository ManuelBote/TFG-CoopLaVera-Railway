<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.CooperativaLaVera.Small"
        parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.CooperativaLaVera.Medium"
        parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.CooperativaLaVera.Large"
        parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ========== Tipografia ========== -->
    <style name="TextAppearance.CooperativaLaVera.Headline5"
        parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Headline6"
        parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/green_900</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Subtitle1"
        parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/green_800</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Body1"
        parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/gray_700</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Body2"
        parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/gray_600</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Caption"
        parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/gray_500</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Button"
        parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.Price"
        parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/green_700</item>
    </style>

    <style name="TextAppearance.CooperativaLaVera.PriceLarge"
        parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/green_700</item>
    </style>

    <!-- ========== Toolbar ========== -->
    <style name="Widget.CooperativaLaVera.Toolbar"
        parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/green_600</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/green_100</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- ========== Botones ========== -->
    <style name="Widget.CooperativaLaVera.Button"
        parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_600</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Widget.CooperativaLaVera.Button.Outlined"
        parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/green_600</item>
        <item name="android:textColor">@color/green_700</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Widget.CooperativaLaVera.Button.Destructive"
        parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_100</item>
        <item name="android:textColor">@color/red_700</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.CooperativaLaVera.Button.Edit"
        parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/blue_100</item>
        <item name="android:textColor">@color/blue_700</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.CooperativaLaVera.BottomNavigation"
        parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/white</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- ========== TextInputLayout ========== -->
    <style name="Widget.CooperativaLaVera.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gray_300</item>
        <item name="hintTextColor">@color/gray_500</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- ========== CardView ========== -->
    <style name="Widget.CooperativaLaVera.CardView"
        parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.CooperativaLaVera.CardView.Padded"
        parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">20dp</item>
    </style>

    <!-- ========== Radio Button ========== -->
    <style name="Widget.CooperativaLaVera.RadioButton"
        parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textColor">@color/gray_700</item>
        <item name="buttonTint">@color/green_600</item>
    </style>

</resources>